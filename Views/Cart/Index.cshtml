@model CartViewModel
@{
    ViewData["Title"] = "Giỏ hàng";
}
<section class="section section-warm">
    <div class="container page-title-block">
        <p class="breadcrumb">Trang chủ &gt; Giỏ hàng</p>
        <h1>Giỏ hàng của bạn</h1>
        <p>Kiểm tra lại sản phẩm trước khi tiến hành tạo đơn hàng.</p>
    </div>

    <div class="container cart-layout">
        <div>
            @if (TempData["Error"] is string errorMessage)
            {
                <div class="form-alert error">@errorMessage</div>
            }

            @if (TempData["Success"] is string successMessage)
            {
                <div class="form-alert success">@successMessage</div>
            }
            <div class="stepper">
                <div class="step active">1 Giỏ hàng</div>
                <div class="step">2 Thanh toán</div>
                <div class="step">3 Hoàn tất</div>
            </div>

            <div class="cart-card">
                @if (!Model.Items.Any())
                {
                    <div class="empty-state compact">
                        <h3>Giỏ hàng đang trống</h3>
                        <p>Bạn chưa thêm sản phẩm nào vào giỏ hàng.</p>
                        <a asp-controller="Product" asp-action="Index" class="btn btn-primary">Khám phá sản phẩm</a>
                    </div>
                }
                else
                {
                    @foreach (var item in Model.Items)
                    {
                        <div class="cart-row">
                            <img src="@item.ImageUrl" alt="@item.Name" />
                            <div class="cart-info">
                                <h3>@item.Name</h3>
                                <p>@item.Subtitle</p>
                                <span class="tag">@item.Label</span>
                                <strong>@item.Price.ToString("N0") VND</strong>
                            </div>
                            <form asp-action="Update" method="post" class="quantity-form" data-cart-quantity-form>
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <div class="quantity-picker">
                                    <button type="button" class="quantity-btn" data-quantity-change="-1" aria-label="Giảm số lượng">-</button>
                                    <input type="number" name="quantity" value="@item.Quantity" min="1" max="@(item.AvailableStock > 0 ? item.AvailableStock : 9999)" readonly data-quantity-input />
                                    <button type="button" class="quantity-btn" data-quantity-change="1" aria-label="Tăng số lượng">+</button>
                                </div>
                                @if (item.AvailableStock > 0)
                                {
                                    <span class="stock-hint" data-stock-hint>Còn @item.AvailableStock sản phẩm</span>
                                }
                                <button type="submit" class="quantity-submit" aria-hidden="true" tabindex="-1">Cập nhật</button>
                            </form>
                            <div class="line-total">@item.LineTotal.ToString("N0")</div>
                            <form asp-action="Remove" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="remove-btn">x</button>
                            </form>
                        </div>
                    }
                }
            </div>
        </div>

        <aside>
            <div class="summary-card">
                <h2>Tóm tắt đơn hàng</h2>
                <div class="summary-row"><span>Tạm tính</span><strong>@Model.SubTotal.ToString("N0")</strong></div>
                <div class="summary-row"><span>Phí vận chuyển</span><strong>@Model.ShippingFee.ToString("N0")</strong></div>
                <div class="summary-row total"><span>Tổng cộng</span><strong>@Model.GrandTotal.ToString("N0")</strong></div>
                @if (Model.Items.Any())
                {
                    <a asp-controller="Checkout" asp-action="Index" class="btn btn-primary full">Tiến hành thanh toán</a>
                }
                else
                {
                    <a asp-controller="Product" asp-action="Index" class="btn btn-primary full">Mua sắm ngay</a>
                }
            </div>
        </aside>
    </div>
</section>
