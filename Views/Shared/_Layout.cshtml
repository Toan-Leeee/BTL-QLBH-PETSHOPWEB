@{
    var bodyClass = ViewBag.BodyClass as string ?? string.Empty;
    var userName = Context.Session.GetString("UserName");
    var userRole = Context.Session.GetString("UserRole");
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var pageCssPath = $"~/css/{currentController}.{currentAction}.css";
    var pageJsPath = $"~/js/{currentController}.{currentAction}.js";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SiêuPet</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="@pageCssPath" asp-append-version="true" />
</head>
<body class="@bodyClass">
    <header class="site-header">
        <div class="container topbar">
            <a asp-controller="Home" asp-action="Index" class="brand">
                <img src="~/images/logo.png" alt="SiêuPet" />
            </a>
            <nav class="main-nav">
                <a class="@((currentController == "Home" && currentAction == "Index") ? "active" : string.Empty)" asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a class="@(currentController == "Product" ? "active" : string.Empty)" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                <a href="#footer">Liên hệ</a>
            </nav>
            <div class="header-actions">
                <form asp-controller="Product" asp-action="Index" method="get" class="search-box">
                    <input type="text" name="Keyword" placeholder="Nhập từ khóa..." />
                </form>
                <a asp-controller="Cart" asp-action="Index" class="pill-link @(currentController == "Cart" ? "active" : string.Empty)">Giỏ hàng</a>
                @if (string.IsNullOrWhiteSpace(userName))
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary">Đăng nhập</a>
                }
                else
                {
                    <div class="user-chip">
                        <span>@userName</span>
                        @if (userRole != "Customer")
                        {
                            <a asp-controller="AdminProducts" asp-action="Products">Admin</a>
                        }
                        <a asp-controller="Account" asp-action="Logout">Đăng xuất</a>
                    </div>
                }
            </div>
        </div>
    </header>

    <main>
        @if (TempData["Success"] is string success)
        {
            <div class="container"><div class="flash success">@success</div></div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="container"><div class="flash error">@error</div></div>
        }
        @RenderBody()
    </main>

    <footer id="footer" class="site-footer">
        <div class="container newsletter">
            <div>
                <h3>Đăng Ký Ngay Để Không Bỏ Lỡ Các Chương Trình Của Chúng Tôi</h3>
            </div>
            <form class="newsletter-form">
                <input type="email" placeholder="Nhập email của bạn..." />
                <button type="button" class="btn btn-accent">Đăng Ký Ngay</button>
            </form>
        </div>
        <div class="container footer-bottom">
            <nav>
                <a asp-controller="Home" asp-action="Index">Trang Chủ</a>
                <a asp-controller="Product" asp-action="Index">Danh Mục</a>
                <a asp-controller="Home" asp-action="Index">Giới Thiệu</a>
                <a href="#footer">Liên Hệ</a>
            </nav>
            <div class="copyright">© 2026 SiêuPet. All rights reserved.</div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="@pageJsPath" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
