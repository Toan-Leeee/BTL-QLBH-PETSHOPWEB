@model AdminCategoriesViewModel
@{
    ViewData["Title"] = "Quản lý danh mục";
}
<section class="admin-section">
    <div class="admin-hero">
        <h1>Quản lý danh mục</h1>
        <p>Thêm, chỉnh sửa và kiểm soát các nhóm thú cưng, phụ kiện đang được bán trong hệ thống.</p>
    </div>

    <div class="admin-summary-strip">
        <div class="admin-summary-card">
            <span>Tổng danh mục</span>
            <strong>@Model.Categories.Count()</strong>
        </div>
        <div class="admin-summary-card">
            <span>Danh mục đang chọn</span>
            <strong>@(Model.SelectedCategory?.MaDanhMuc ?? "--")</strong>
        </div>
        <div class="admin-summary-card">
            <span>Số sản phẩm gắn</span>
            <strong>@(Model.SelectedCategory?.SanPhams.Count ?? 0)</strong>
        </div>
    </div>

    <div class="admin-panel search-panel">
        <form method="get" class="admin-filter-grid three-wide">
            <input type="text" name="keyword" value="@Model.Keyword" placeholder="Tìm theo mã, tên danh mục..." />
            <div></div>
            <div class="inline-actions end">
                <button class="btn btn-primary" type="submit">Tìm kiếm</button>
                <a asp-action="Categories" class="btn btn-outline">Làm mới</a>
            </div>
        </form>
    </div>

    <div class="admin-grid two-col admin-stretch">
        <div class="admin-panel">
            <div class="section-head compact with-meta">
                <div>
                    <h2>Danh sách danh mục</h2>
                    <small>@Model.Categories.Count() danh mục</small>
                </div>
            </div>

            @if (!Model.Categories.Any())
            {
                <div class="admin-empty-state">
                    <h3>Chưa có danh mục</h3>
                    <p>Hãy tạo danh mục đầu tiên để gắn sản phẩm.</p>
                </div>
            }
            else
            {
                <div class="table-wrap compact-table">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Mã DM</th>
                                <th>Tên danh mục</th>
                                <th>Số sản phẩm</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.Categories)
                        {
                            <tr class="@(item.MaDanhMuc == Model.SelectedId ? "row-selected" : string.Empty)">
                                <td>@item.MaDanhMuc</td>
                                <td>
                                    <div class="table-title">@item.TenDanhMuc</div>
                                    <small>@item.MoTa</small>
                                </td>
                                <td><span class="status-chip neutral">@item.SanPhams.Count sản phẩm</span></td>
                                <td>
                                    <div class="inline-actions">
                                        <a asp-action="Categories"
                                           asp-route-keyword="@Model.Keyword"
                                           asp-route-selectedId="@item.MaDanhMuc"
                                           class="btn btn-outline small">Sửa</a>
                                        <form asp-action="DeleteCategory" method="post" class="inline-form" data-confirm="Xóa danh mục này?">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.MaDanhMuc" />
                                            <button class="btn btn-danger small" type="submit">Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="admin-side-stack sticky-panel">
            <div class="record-card" data-admin-record-card>
                <h3>Thông tin danh mục</h3>
                @if (Model.SelectedCategory is null)
                {
                    <p class="muted-note">Chọn một danh mục để xem nhanh mô tả và số sản phẩm đang được gắn.</p>
                }
                else
                {
                    <div class="info-pairs">
                        <div><strong>Tên danh mục</strong>@Model.SelectedCategory.TenDanhMuc</div>
                        <div><strong>Mô tả</strong>@(Model.SelectedCategory.MoTa ?? "Chưa có mô tả")</div>
                        <div><strong>Số sản phẩm</strong>@Model.SelectedCategory.SanPhams.Count</div>
                    </div>
                }
            </div>

            <div class="admin-panel form-panel">
                <div class="section-head compact with-meta">
                    <div>
                        <h2>@(string.IsNullOrWhiteSpace(Model.FormCategory.MaDanhMuc) ? "Thêm danh mục" : "Chỉnh sửa danh mục")</h2>
                        <small>@(string.IsNullOrWhiteSpace(Model.FormCategory.MaDanhMuc) ? "Tạo nhóm sản phẩm mới" : $"Đang sửa {Model.FormCategory.MaDanhMuc}")</small>
                    </div>
                </div>

                <form asp-action="SaveCategory" method="post" class="stack-form" data-admin-form="categories">
                    @Html.AntiForgeryToken()
                    <input name="MaDanhMuc" value="@Model.FormCategory.MaDanhMuc" placeholder="Mã danh mục (để trống để tự sinh)" />
                    <input name="TenDanhMuc" value="@Model.FormCategory.TenDanhMuc" placeholder="Tên danh mục" />
                    <textarea name="MoTa" rows="5" placeholder="Mô tả chi tiết" data-auto-resize>@Model.FormCategory.MoTa</textarea>
                    <div class="hint">Danh mục được dùng để nhóm sản phẩm ở giao diện bán hàng và admin.</div>
                    <div class="inline-actions stretch">
                        <button class="btn btn-primary full" type="submit">Lưu danh mục</button>
                        <a asp-action="Categories" class="btn btn-outline full">Tạo mới</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
