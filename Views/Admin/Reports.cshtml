@{
    ViewData["Title"] = "Báo cáo";
}
<section class="admin-section">
    <div class="admin-hero">
        <h1>Báo cáo nhanh</h1>
        <p>Thống kê dữ liệu theo đúng ERD Word: nhân viên, khách hàng, danh mục, sản phẩm, đơn hàng và phiếu nhập.</p>
    </div>
    <div class="stats-grid">
        <div class="stat-card"><span>Doanh thu hoàn tất</span><strong data-stat-value="@(((decimal)ViewBag.TotalRevenue).ToString("F0", System.Globalization.CultureInfo.InvariantCulture))">@(((decimal)ViewBag.TotalRevenue).ToString("N0"))</strong><small>VND</small></div>
        <div class="stat-card"><span>Tổng đơn hàng</span><strong data-stat-value="@ViewBag.TotalOrders">@ViewBag.TotalOrders</strong><small>Đơn đã ghi nhận</small></div>
        <div class="stat-card"><span>Sản phẩm hiển thị</span><strong data-stat-value="@ViewBag.ActiveProducts">@ViewBag.ActiveProducts</strong><small>Trên tổng @ViewBag.TotalProducts sản phẩm</small></div>
        <div class="stat-card"><span>Tài khoản nhân viên</span><strong data-stat-value="@ViewBag.TotalEmployees">@ViewBag.TotalEmployees</strong><small>Đang hoạt động</small></div>
        <div class="stat-card"><span>Danh mục</span><strong data-stat-value="@ViewBag.TotalCategories">@ViewBag.TotalCategories</strong><small>Nhóm sản phẩm</small></div>
        <div class="stat-card"><span>Khách hàng</span><strong data-stat-value="@ViewBag.TotalCustomers">@ViewBag.TotalCustomers</strong><small>Tài khoản đã đăng ký</small></div>
        <div class="stat-card"><span>Phiếu nhập</span><strong data-stat-value="@ViewBag.TotalImports">@ViewBag.TotalImports</strong><small>Lịch sử nhập kho</small></div>
    </div>
</section>
