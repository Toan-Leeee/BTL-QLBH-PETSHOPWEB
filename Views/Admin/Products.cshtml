@model AdminProductsViewModel
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}
<section class="admin-section">
    <div class="admin-hero">
        <h1>Quản lý sản phẩm</h1>
        <p>Thêm, sửa và xóa trực tiếp sản phẩm trong cơ sở dữ liệu.</p>
    </div>

    <div class="admin-panel search-panel">
        <form method="get" class="admin-filter-grid three-wide">
            <input type="text" name="keyword" value="@Model.Keyword" placeholder="Tìm theo tên, mã SKU..." />
            <select name="statusFilter">
                <option value="">Tất cả trạng thái</option>
                @if (Model.StatusFilter == "active")
                {
                    <option value="active" selected>Đang hiển thị</option>
                }
                else
                {
                    <option value="active">Đang hiển thị</option>
                }
                @if (Model.StatusFilter == "hidden")
                {
                    <option value="hidden" selected>Đang ẩn</option>
                }
                else
                {
                    <option value="hidden">Đang ẩn</option>
                }
            </select>
            <div class="inline-actions end">
                <button class="btn btn-primary" type="submit">Tìm kiếm</button>
                <a asp-action="Products" class="btn btn-outline">Làm mới</a>
            </div>
        </form>
    </div>

    <div class="admin-grid two-col admin-stretch">
        <div class="admin-panel">
            <div class="section-head compact with-meta">
                <div>
                    <h2>Danh sách sản phẩm</h2>
                    <small>@Model.Products.Count() sản phẩm / phụ kiện</small>
                </div>
            </div>

            @if (!Model.Products.Any())
            {
                <div class="admin-empty-state">
                    <h3>Chưa có dữ liệu phù hợp</h3>
                    <p>Hãy thêm sản phẩm mới hoặc thay đổi bộ lọc tìm kiếm.</p>
                </div>
            }
            else
            {
                <div class="table-wrap products-table">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>SKU</th>
                                <th>Tên sản phẩm</th>
                                <th>Danh mục</th>
                                <th>Giá</th>
                                <th>Tồn</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.Products)
                        {
                            <tr class="@(item.MaSanPham == Model.SelectedId ? "row-selected" : string.Empty)">
                                <td>@item.MaSanPham</td>
                                <td>
                                    <div class="table-title">@item.TenSanPham</div>
                                    <small>@item.MoTa</small>
                                </td>
                                <td>@item.DanhMuc?.TenDanhMuc</td>
                                <td>@item.GiaBan.ToString("N0")</td>
                                <td>@item.SoLuongTonKho</td>
                                <td>
                                    <span class="status-chip @(item.TrangThai ? "success" : "danger")">
                                        @(item.TrangThai ? "Đang hiển thị" : "Đã ẩn")
                                    </span>
                                </td>
                                <td>
                                    <div class="inline-actions">
                                        <a asp-action="Products"
                                           asp-route-keyword="@Model.Keyword"
                                           asp-route-statusFilter="@Model.StatusFilter"
                                           asp-route-selectedId="@item.MaSanPham"
                                           class="btn btn-outline small">Sửa</a>

                                        <form asp-action="DeleteProduct" method="post" class="inline-form" data-confirm="Xóa sản phẩm này khỏi cơ sở dữ liệu?">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.MaSanPham" />
                                            <button class="btn btn-danger small" type="submit">Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="admin-panel form-panel products-form-panel sticky-panel">
            <div class="section-head compact with-meta">
                <div>
                    <h2>@(string.IsNullOrWhiteSpace(Model.FormProduct.MaSanPham) ? "Thêm sản phẩm mới" : "Chỉnh sửa sản phẩm")</h2>
                    <small>@(string.IsNullOrWhiteSpace(Model.FormProduct.MaSanPham) ? "Tạo sản phẩm mới trong hệ thống" : $"Đang chỉnh sửa {Model.FormProduct.MaSanPham}")</small>
                </div>
            </div>

            <form asp-action="SaveProduct" method="post" class="stack-form" data-admin-form="products">
                @Html.AntiForgeryToken()
                <input name="MaSanPham" value="@Model.FormProduct.MaSanPham" placeholder="Mã sản phẩm (để trống để tự sinh)" />
                <input name="TenSanPham" value="@Model.FormProduct.TenSanPham" placeholder="Tên thú cưng / sản phẩm" />

                <select name="MaDanhMuc">
                    @foreach (var category in Model.Categories)
                    {
                        if (Model.FormProduct.MaDanhMuc == category.MaDanhMuc)
                        {
                            <option value="@category.MaDanhMuc" selected>@category.TenDanhMuc</option>
                        }
                        else
                        {
                            <option value="@category.MaDanhMuc">@category.TenDanhMuc</option>
                        }
                    }
                </select>

                <div class="form-grid two">
                    <input name="GiaBan" type="number" min="0" step="1000" value="@Model.FormProduct.GiaBan" placeholder="Giá bán" />
                    <input name="SoLuongTonKho" type="number" min="0" value="@Model.FormProduct.SoLuongTonKho" placeholder="Số lượng tồn" />
                </div>

                <input name="HinhAnh"
                       value="@Model.FormProduct.HinhAnh"
                       placeholder="Đường dẫn ảnh, ví dụ /images/products/default.svg"
                       data-product-image-input />
                <div class="admin-image-preview">
                    <img src="@(string.IsNullOrWhiteSpace(Model.FormProduct.HinhAnh) ? "/images/products/default.svg" : Model.FormProduct.HinhAnh)"
                         alt="Ảnh sản phẩm"
                         data-product-image-preview />
                    <small>Xem trước ảnh đang gắn cho sản phẩm.</small>
                </div>
                <textarea name="MoTa" rows="4" placeholder="Mô tả">@Model.FormProduct.MoTa</textarea>

                <label class="checkbox-line no-border">
                    @if (Model.FormProduct.TrangThai)
                    {
                        <input type="checkbox" name="TrangThai" value="true" checked />
                    }
                    else
                    {
                        <input type="checkbox" name="TrangThai" value="true" />
                    }
                    <input type="hidden" name="TrangThai" value="false" />
                    <span>Hiển thị sản phẩm trên giao diện bán hàng</span>
                </label>

                <div class="inline-actions stretch">
                    <button class="btn btn-primary full" type="submit">Lưu sản phẩm</button>
                    <a asp-action="Products" class="btn btn-outline full">Tạo mới</a>
                </div>
            </form>
        </div>
    </div>
</section>
