@model AdminProductsViewModel
@{
    ViewData["Title"] = "Quan ly san pham";
}
<section class="admin-section">
    <div class="admin-hero">
        <h1>Quan ly san pham</h1>
        <p>Them, sua va xoa truc tiep san pham trong database.</p>
    </div>

    <div class="admin-panel search-panel">
        <form method="get" class="admin-filter-grid three-wide">
            <input type="text" name="keyword" value="@Model.Keyword" placeholder="Tim theo ten, ma SKU..." />
            <select name="statusFilter">
                <option value="">Tat ca trang thai</option>
                @if (Model.StatusFilter == "active")
                {
                    <option value="active" selected>Dang hien thi</option>
                }
                else
                {
                    <option value="active">Dang hien thi</option>
                }
                @if (Model.StatusFilter == "hidden")
                {
                    <option value="hidden" selected>Dang an</option>
                }
                else
                {
                    <option value="hidden">Dang an</option>
                }
            </select>
            <div class="inline-actions end">
                <button class="btn btn-primary" type="submit">Tim kiem</button>
                <a asp-action="Products" class="btn btn-outline">Lam moi</a>
            </div>
        </form>
    </div>

    <div class="admin-grid two-col admin-stretch">
        <div class="admin-panel">
            <div class="section-head compact with-meta">
                <div>
                    <h2>Danh sach san pham</h2>
                    <small>@Model.Products.Count() san pham / phu kien</small>
                </div>
            </div>

            @if (!Model.Products.Any())
            {
                <div class="admin-empty-state">
                    <h3>Chua co du lieu phu hop</h3>
                    <p>Hay them san pham moi hoac thay doi bo loc tim kiem.</p>
                </div>
            }
            else
            {
                <div class="table-wrap products-table">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>SKU</th>
                                <th>Ten san pham</th>
                                <th>Danh muc</th>
                                <th>Gia</th>
                                <th>Ton</th>
                                <th>Trang thai</th>
                                <th>Hanh dong</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.Products)
                        {
                            <tr class="@(item.MaSanPham == Model.SelectedId ? "row-selected" : string.Empty)">
                                <td>@item.MaSanPham</td>
                                <td>
                                    <div class="table-title">@item.TenSanPham</div>
                                    <small>@item.MoTa</small>
                                </td>
                                <td>@item.DanhMuc?.TenDanhMuc</td>
                                <td>@item.GiaBan.ToString("N0")</td>
                                <td>@item.SoLuongTonKho</td>
                                <td>
                                    <span class="status-chip @(item.TrangThai ? "success" : "danger")">
                                        @(item.TrangThai ? "Dang hien thi" : "Da an")
                                    </span>
                                </td>
                                <td>
                                    <div class="inline-actions">
                                        <a asp-action="Products"
                                           asp-route-keyword="@Model.Keyword"
                                           asp-route-statusFilter="@Model.StatusFilter"
                                           asp-route-selectedId="@item.MaSanPham"
                                           class="btn btn-outline small">Sua</a>

                                        <form asp-action="DeleteProduct" method="post" class="inline-form" data-confirm="Xoa san pham nay khoi database?">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.MaSanPham" />
                                            <button class="btn btn-danger small" type="submit">Xoa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="admin-panel form-panel products-form-panel sticky-panel">
            <div class="section-head compact with-meta">
                <div>
                    <h2>@(string.IsNullOrWhiteSpace(Model.FormProduct.MaSanPham) ? "Them san pham moi" : "Chinh sua san pham")</h2>
                    <small>@(string.IsNullOrWhiteSpace(Model.FormProduct.MaSanPham) ? "Tao san pham moi trong he thong" : $"Dang chinh sua {Model.FormProduct.MaSanPham}")</small>
                </div>
            </div>

            <form asp-action="SaveProduct" method="post" class="stack-form" data-admin-form="products">
                @Html.AntiForgeryToken()
                <input name="MaSanPham" value="@Model.FormProduct.MaSanPham" placeholder="Ma san pham (de trong de tu sinh)" />
                <input name="TenSanPham" value="@Model.FormProduct.TenSanPham" placeholder="Ten thu cung / san pham" />

                <select name="MaDanhMuc">
                    @foreach (var category in Model.Categories)
                    {
                        if (Model.FormProduct.MaDanhMuc == category.MaDanhMuc)
                        {
                            <option value="@category.MaDanhMuc" selected>@category.TenDanhMuc</option>
                        }
                        else
                        {
                            <option value="@category.MaDanhMuc">@category.TenDanhMuc</option>
                        }
                    }
                </select>

                <div class="form-grid two">
                    <input name="GiaBan" type="number" min="0" step="1000" value="@Model.FormProduct.GiaBan" placeholder="Gia ban" />
                    <input name="SoLuongTonKho" type="number" min="0" value="@Model.FormProduct.SoLuongTonKho" placeholder="So luong ton" />
                </div>

                <input name="HinhAnh"
                       value="@Model.FormProduct.HinhAnh"
                       placeholder="Duong dan anh, vi du /images/products/default.svg"
                       data-product-image-input />
                <div class="admin-image-preview">
                    <img src="@(string.IsNullOrWhiteSpace(Model.FormProduct.HinhAnh) ? "/images/products/default.svg" : Model.FormProduct.HinhAnh)"
                         alt="Anh san pham"
                         data-product-image-preview />
                    <small>Xem truoc anh dang gan cho san pham.</small>
                </div>
                <textarea name="MoTa" rows="4" placeholder="Mo ta">@Model.FormProduct.MoTa</textarea>

                <label class="checkbox-line no-border">
                    @if (Model.FormProduct.TrangThai)
                    {
                        <input type="checkbox" name="TrangThai" value="true" checked />
                    }
                    else
                    {
                        <input type="checkbox" name="TrangThai" value="true" />
                    }
                    <input type="hidden" name="TrangThai" value="false" />
                    <span>Hien thi san pham tren giao dien ban hang</span>
                </label>

                <div class="inline-actions stretch">
                    <button class="btn btn-primary full" type="submit">Luu san pham</button>
                    <a asp-action="Products" class="btn btn-outline full">Tao moi</a>
                </div>
            </form>
        </div>
    </div>
</section>
