@model AdminAccountsViewModel
@{
    ViewData["Title"] = "Quan ly tai khoan";
}
<section class="admin-section">
    <div class="admin-hero">
        <h1>Quan ly tai khoan</h1>
        <p>Quan tri tai khoan admin va nhan vien, cho phep them sua xoa truc tiep trong database.</p>
    </div>

    <div class="admin-panel search-panel">
        <form method="get" class="admin-filter-grid three-wide">
            <input type="text" name="keyword" value="@Model.Keyword" placeholder="Tim theo ten, email, so dien thoai hoac vai tro..." />
            <input type="hidden" name="selectedId" value="@Model.SelectedId" />
            <div></div>
            <div class="inline-actions end">
                <button class="btn btn-primary" type="submit">Tim kiem</button>
                <a asp-action="Accounts" class="btn btn-outline">Lam moi</a>
            </div>
        </form>
    </div>

    <div class="admin-grid two-col admin-stretch">
        <div class="admin-panel">
            <div class="section-head compact with-meta">
                <div>
                    <h2>Danh sach tai khoan</h2>
                    <small>@Model.Employees.Count() nhan su dang hoat dong</small>
                </div>
            </div>

            @if (!Model.Employees.Any())
            {
                <div class="admin-empty-state">
                    <h3>Khong tim thay tai khoan phu hop</h3>
                    <p>Hay dieu chinh tu khoa tim kiem hoac tao moi mot tai khoan nhan vien.</p>
                </div>
            }
            else
            {
                <div class="table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Ho ten</th>
                                <th>Email</th>
                                <th>So dien thoai</th>
                                <th>Vai tro</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.Employees)
                        {
                            <tr class="@(item.MaNhanVien == Model.SelectedId ? "row-selected" : string.Empty)">
                                <td>@item.HoTen</td>
                                <td>@item.Email</td>
                                <td>@item.SoDienThoai</td>
                                <td><span class="status-chip neutral">@item.VaiTro</span></td>
                                <td>
                                    <div class="inline-actions">
                                        <a asp-action="Accounts"
                                           asp-route-keyword="@Model.Keyword"
                                           asp-route-selectedId="@item.MaNhanVien"
                                           class="btn btn-outline small">Sua</a>
                                        <form asp-action="DeleteEmployee" method="post" class="inline-form" data-confirm="Xoa tai khoan nay khoi database?">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.MaNhanVien" />
                                            <button class="btn btn-danger small" type="submit">Xoa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="admin-side-stack sticky-panel">
            <div class="admin-panel profile-card-admin" data-admin-profile-card>
                <h2>Chi tiet quyen</h2>
                @if (Model.SelectedEmployee is null)
                {
                    <div class="admin-empty-state compact">
                        <p>Chon mot tai khoan o danh sach ben trai de xem chi tiet.</p>
                    </div>
                }
                else
                {
                    var initials = string.Join(string.Empty, Model.SelectedEmployee.HoTen.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpperInvariant();
                    <div class="avatar-circle">@initials</div>
                    <h3>@Model.SelectedEmployee.HoTen</h3>
                    <p>@Model.SelectedEmployee.VaiTro</p>
                }
            </div>

            <div class="admin-panel form-panel">
                <div class="section-head compact with-meta">
                    <div>
                        <h2>@(string.IsNullOrWhiteSpace(Model.FormEmployee.MaNhanVien) ? "Tao tai khoan moi" : "Chinh sua tai khoan")</h2>
                        <small>@(string.IsNullOrWhiteSpace(Model.FormEmployee.MaNhanVien) ? "Them nhan su moi vao he thong" : $"Ma nhan vien: {Model.FormEmployee.MaNhanVien}")</small>
                    </div>
                </div>

                <form asp-action="SaveEmployee" method="post" class="stack-form" data-admin-form="accounts">
                    @Html.AntiForgeryToken()
                    <input name="MaNhanVien" value="@Model.FormEmployee.MaNhanVien" placeholder="Ma nhan vien (de trong de tu sinh)" />
                    <input name="HoTen" value="@Model.FormEmployee.HoTen" placeholder="Ho va ten" />
                    <input name="Email" value="@Model.FormEmployee.Email" placeholder="Email dang nhap" />
                    <input name="SoDienThoai" value="@Model.FormEmployee.SoDienThoai" placeholder="So dien thoai" />
                    <div class="form-grid two">
                        <input name="VaiTro" value="@Model.FormEmployee.VaiTro" placeholder="Vai tro / phong ban" />
                        <input name="NgayVaoLam" type="date" value="@Model.FormEmployee.NgayVaoLam?.ToString("yyyy-MM-dd")" />
                    </div>
                    <input name="MatKhau" value="@Model.FormEmployee.MatKhau" placeholder="Mat khau (de trong neu giu nguyen)" />
                    <div class="inline-actions stretch">
                        <button class="btn btn-primary full" type="submit">Luu tai khoan</button>
                        <a asp-action="Accounts" class="btn btn-outline full">Tao moi</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
