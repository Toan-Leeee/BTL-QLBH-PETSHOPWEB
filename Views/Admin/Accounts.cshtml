@model AdminAccountsViewModel
@{
    ViewData["Title"] = "Quản lý tài khoản";
}
<section class="admin-section">
    <div class="admin-hero">
        <h1>Quản lý tài khoản</h1>
        <p>Quản trị tài khoản admin và nhân viên, cho phép thêm, sửa, xóa trực tiếp trong cơ sở dữ liệu.</p>
    </div>

    <div class="admin-panel search-panel">
        <form method="get" class="admin-filter-grid three-wide">
            <input type="text" name="keyword" value="@Model.Keyword" placeholder="Tìm theo tên, email, số điện thoại hoặc vai trò..." />
            <input type="hidden" name="selectedId" value="@Model.SelectedId" />
            <div></div>
            <div class="inline-actions end">
                <button class="btn btn-primary" type="submit">Tìm kiếm</button>
                <a asp-action="Accounts" class="btn btn-outline">Làm mới</a>
            </div>
        </form>
    </div>

    <div class="admin-grid two-col admin-stretch">
        <div class="admin-panel">
            <div class="section-head compact with-meta">
                <div>
                    <h2>Danh sách tài khoản</h2>
                    <small>@Model.Employees.Count() nhân sự đang hoạt động</small>
                </div>
            </div>

            @if (!Model.Employees.Any())
            {
                <div class="admin-empty-state">
                    <h3>Không tìm thấy tài khoản phù hợp</h3>
                    <p>Hãy điều chỉnh từ khóa tìm kiếm hoặc tạo mới một tài khoản nhân viên.</p>
                </div>
            }
            else
            {
                <div class="table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Họ tên</th>
                                <th>Email</th>
                                <th>Số điện thoại</th>
                                <th>Vai trò</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.Employees)
                        {
                            <tr class="@(item.MaNhanVien == Model.SelectedId ? "row-selected" : string.Empty)">
                                <td>@item.HoTen</td>
                                <td>@item.Email</td>
                                <td>@item.SoDienThoai</td>
                                <td><span class="status-chip neutral">@item.VaiTro</span></td>
                                <td>
                                    <div class="inline-actions">
                                        <a asp-action="Accounts"
                                           asp-route-keyword="@Model.Keyword"
                                           asp-route-selectedId="@item.MaNhanVien"
                                           class="btn btn-outline small">Sửa</a>
                                        <form asp-action="DeleteEmployee" method="post" class="inline-form" data-confirm="Xóa tài khoản này khỏi cơ sở dữ liệu?">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.MaNhanVien" />
                                            <button class="btn btn-danger small" type="submit">Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="admin-side-stack sticky-panel">
            <div class="admin-panel profile-card-admin" data-admin-profile-card>
                <h2>Chi tiết quyền</h2>
                @if (Model.SelectedEmployee is null)
                {
                    <div class="admin-empty-state compact">
                        <p>Chọn một tài khoản ở danh sách bên trái để xem chi tiết.</p>
                    </div>
                }
                else
                {
                    var initials = string.Join(string.Empty, Model.SelectedEmployee.HoTen.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpperInvariant();
                    <div class="avatar-circle">@initials</div>
                    <h3>@Model.SelectedEmployee.HoTen</h3>
                    <p>@Model.SelectedEmployee.VaiTro</p>
                }
            </div>

            <div class="admin-panel form-panel">
                <div class="section-head compact with-meta">
                    <div>
                        <h2>@(string.IsNullOrWhiteSpace(Model.FormEmployee.MaNhanVien) ? "Tạo tài khoản mới" : "Chỉnh sửa tài khoản")</h2>
                        <small>@(string.IsNullOrWhiteSpace(Model.FormEmployee.MaNhanVien) ? "Thêm nhân sự mới vào hệ thống" : $"Mã nhân viên: {Model.FormEmployee.MaNhanVien}")</small>
                    </div>
                </div>

                <form asp-action="SaveEmployee" method="post" class="stack-form" data-admin-form="accounts">
                    @Html.AntiForgeryToken()
                    <input name="MaNhanVien" value="@Model.FormEmployee.MaNhanVien" placeholder="Mã nhân viên (để trống để tự sinh)" />
                    <input name="HoTen" value="@Model.FormEmployee.HoTen" placeholder="Họ và tên" />
                    <input name="Email" value="@Model.FormEmployee.Email" placeholder="Email đăng nhập" />
                    <input name="SoDienThoai" value="@Model.FormEmployee.SoDienThoai" placeholder="Số điện thoại" />
                    <div class="form-grid two">
                        <input name="VaiTro" value="@Model.FormEmployee.VaiTro" placeholder="Vai trò / phòng ban" />
                        <input name="NgayVaoLam" type="date" value="@Model.FormEmployee.NgayVaoLam?.ToString("yyyy-MM-dd")" />
                    </div>
                    <input name="MatKhau" value="@Model.FormEmployee.MatKhau" placeholder="Mật khẩu (để trống nếu giữ nguyên)" />
                    <div class="inline-actions stretch">
                        <button class="btn btn-primary full" type="submit">Lưu tài khoản</button>
                        <a asp-action="Accounts" class="btn btn-outline full">Tạo mới</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
